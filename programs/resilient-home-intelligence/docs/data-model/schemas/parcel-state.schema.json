{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/resilient-home-intelligence/schemas/parcel-state.schema.json",
  "title": "RHI Parcel State",
  "type": "object",
  "required": [
    "parcel_id",
    "computed_at",
    "stay_status",
    "enter_status",
    "escape_status",
    "asset_status",
    "confidence",
    "evidence_mode",
    "reasons",
    "hazards",
    "freshness",
    "provenance_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "parcel_id": {
      "type": "string",
      "minLength": 1
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "stay_status": {
      "$ref": "#/$defs/status"
    },
    "enter_status": {
      "$ref": "#/$defs/status"
    },
    "escape_status": {
      "$ref": "#/$defs/status"
    },
    "asset_status": {
      "$ref": "#/$defs/status"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_mode": {
      "type": "string",
      "enum": [
        "local_only",
        "local_plus_public",
        "public_only",
        "insufficient"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "hazards": {
      "type": "object",
      "required": [
        "smoke_probability",
        "flood_probability",
        "heat_probability"
      ],
      "additionalProperties": false,
      "properties": {
        "smoke_probability": {
          "$ref": "#/$defs/probability"
        },
        "flood_probability": {
          "$ref": "#/$defs/probability"
        },
        "heat_probability": {
          "$ref": "#/$defs/probability"
        }
      }
    },
    "freshness": {
      "type": "object",
      "required": [
        "latest_observation_at",
        "seconds_since_latest",
        "stale"
      ],
      "additionalProperties": false,
      "properties": {
        "latest_observation_at": {
          "type": "string",
          "format": "date-time"
        },
        "seconds_since_latest": {
          "type": "integer",
          "minimum": 0
        },
        "stale": {
          "type": "boolean"
        }
      }
    },
    "provenance_summary": {
      "type": "object",
      "required": [
        "observation_count",
        "source_modes"
      ],
      "additionalProperties": false,
      "properties": {
        "observation_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "observation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "safe",
        "caution",
        "unsafe",
        "unknown"
      ]
    },
    "probability": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
