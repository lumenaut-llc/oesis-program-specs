{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/resilient-home-intelligence/schemas/operator-access-event.schema.json",
  "title": "RHI Operator Access Event",
  "type": "object",
  "required": [
    "event_id",
    "occurred_at",
    "actor",
    "action",
    "parcel_id",
    "data_classes",
    "justification"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "parcel_id": {
      "type": "string",
      "minLength": 1
    },
    "data_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "private_parcel_data",
          "shared_data",
          "public_context",
          "derived_parcel_state",
          "administrative_record"
        ]
      },
      "minItems": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    }
  }
}
