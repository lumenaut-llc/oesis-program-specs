---
const {
  eyebrow,
  title,
  lede,
  tagline,
  meta = [],
  pageLinks = [],
  actions = [],
  asideLabel,
  asideTitle,
  asideItems = [],
  versionBar,
  heroImage
} = Astro.props;
---

{versionBar && (
  <div class="version-bar">
    <span class="version-bar-label">{versionBar}</span>
    {meta.length > 0 && (
      <div class="version-bar-meta">
        {meta.map((item) => <span>{item}</span>)}
      </div>
    )}
  </div>
)}

<header class="hero">
  <div class="hero-top">
    <p class="eyebrow">{eyebrow}</p>
    {pageLinks.length > 0 && (
      <nav class="section-nav" aria-label="Page sections">
        {pageLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
    )}
  </div>
  <div class="hero-grid">
    <div>
      <h1>{title}</h1>
      <p class="lede">{lede}</p>
      {tagline && <p class="hero-tagline">{tagline}</p>}
      {!versionBar && meta.length > 0 && (
        <div class="meta-strip" aria-label="Release metadata">
          {meta.map((item) => <span>{item}</span>)}
        </div>
      )}
      {actions.length > 0 && (
        <div class="hero-actions">
          {actions.map((action) => (
            <a
              class={`button ${action.variant === "secondary" ? "button-secondary" : "button-primary"}`}
              href={action.href}
            >
              {action.label}
            </a>
          ))}
        </div>
      )}
    </div>
    {heroImage ? (
      <div class="hero-image-wrap">
        <img src={heroImage.src} alt={heroImage.alt || ""} class="hero-image" loading="eager" />
      </div>
    ) : (asideTitle || asideItems.length > 0) ? (
      <aside class="hero-aside">
        {asideLabel && <p class="kicker">{asideLabel}</p>}
        {asideTitle && <h2>{asideTitle}</h2>}
        {asideItems.length > 0 && (
          <ul>
            {asideItems.map((item) => <li>{item}</li>)}
          </ul>
        )}
      </aside>
    ) : null}
  </div>
</header>
