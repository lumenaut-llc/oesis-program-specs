---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHero from "../components/PageHero.astro";
import { repoLinks } from "../lib/repo-links";

const pageLinks = [
  { href: "index.html#open-release", label: "Main release" },
  { href: "#public-v1", label: "Public v1" },
  { href: "#metadata", label: "Required metadata" },
  { href: "faq.html", label: "FAQ" },
  { href: "release-notes.html", label: "Release notes" },
  { href: "#read-first", label: "Read first" }
];

const actions = [
  { href: "index.html#data-boundary", label: "Back to the release page" },
  { href: repoLinks.datasetReleasePolicy, label: "Read the dataset policy", variant: "secondary" }
];

const heroAsideItems = [
  "It is project-controlled.",
  "It is intentionally designated for public release.",
  "It carries explicit dataset terms and scope notes.",
  "It does not silently convert future participant data into open data."
];

const publicCards = [
  {
    label: "Scope",
    title: "Project-controlled release artifact",
    body:
      "The public v1 dataset is the project-controlled dataset or derived release artifacts that the project intentionally ships as part of the open release."
  },
  {
    label: "Terms",
    title: "Dataset-specific license",
    body:
      "The current recommended public dataset license is CDLA-Sharing-1.0, not a blanket assumption that all repository content shares one license."
  },
  {
    label: "Boundary",
    title: "Not every parcel-linked record is public",
    body:
      "Future participant-contributed parcel-linked data remains private by default unless a separate later decision explicitly changes that."
  }
];

const mayBePublic = [
  "project-controlled raw field observations intentionally included in the release",
  "derived parcel-state outputs tied to the v1 release package",
  "approved public shared snapshots with clear scope and provenance",
  "schemas, validators, and synthetic fixtures that help people use the release"
];

const notPublic = [
  "future participant-contributed parcel-linked data",
  "account or household identifiers outside the intentional public scope",
  "non-cleared third-party data and operator-only records",
  "accidental secrets, credentials, or low-participation data that enables singling out"
];

const metadataCards = [
  {
    title: "License",
    body:
      "Attach the explicit dataset license text or a clear pointer to it so reuse terms are visible at the time of release."
  },
  {
    title: "Provenance",
    body:
      "State where the data came from, who had authority to release it, and what transformations were applied before publication."
  },
  {
    title: "Date range and freshness",
    body:
      "Include the date range covered by the release and any caveats about staleness, gaps, or partial collection."
  },
  {
    title: "Scope and exclusions",
    body:
      "Explain what is included, what is intentionally excluded, and why this release does not imply a broader public-data promise."
  }
];

const checklist = [
  "Confirm the project has clear authority to publish the dataset.",
  "Confirm the dataset is intentionally designated as a public release artifact.",
  "Attach the dataset license, provenance notes, date range, and scope caveats.",
  "Confirm that future participant data is not being released by accident.",
  "Confirm that no operator-only, secret, or non-cleared third-party material is embedded."
];

const referenceCards = [
  {
    title: "Parcel-state schema",
    body:
      "Use the parcel-state schema to understand the public shape of derived parcel-level outputs.",
    href: repoLinks.parcelStateSchema,
    label: "Open schema"
  },
  {
    title: "Observation schema",
    body:
      "Use the node-observation schema to understand the public reference shape for normalized observations.",
    href: repoLinks.nodeObservationSchema,
    label: "Open schema"
  },
  {
    title: "Example parcel-state payload",
    body:
      "The example payload is the fastest public artifact for understanding the output shape before a real public dataset bundle is attached.",
    href: repoLinks.parcelStateExample,
    label: "Open example"
  },
  {
    title: "License matrix",
    body:
      "Dataset reuse terms should always be read together with the broader asset-class licensing matrix.",
    href: repoLinks.rootLicenses,
    label: "Open licensing matrix"
  }
];

const readFirstLinks = [
  { href: repoLinks.datasetReleasePolicy, label: "Dataset release policy" },
  { href: repoLinks.rootLicenses, label: "Licensing matrix" },
  { href: repoLinks.dataOwnership, label: "Data ownership" },
  { href: repoLinks.privacy, label: "Privacy" },
  { href: repoLinks.publicReleaseScope, label: "Public release scope" },
  { href: repoLinks.ip, label: "IP position" },
  { href: repoLinks.releaseNotice, label: "Release notice" },
  { href: "index.html", label: "Main release page" },
  { href: "faq.html", label: "FAQ" },
  { href: "release-notes.html", label: "Release notes" }
];
---

<SiteLayout
  title="Resilient Home Intelligence Public Dataset Boundary"
  description="Public dataset boundary for the Resilient Home Intelligence April 14 open release."
  ogDescription="What the intentionally public v1 dataset can include, what stays private, and what metadata should accompany the release."
>
  <Fragment slot="hero">
    <PageHero
      eyebrow="Dataset Boundary"
      title="Public dataset boundary for the v1 release."
      lede="This page explains what the intentionally public project-controlled v1 dataset can include, what still stays private by default, and what metadata should accompany any public dataset release."
      tagline="Intentional release, explicit terms, clear provenance."
      pageLinks={pageLinks}
      actions={actions}
      asideLabel="At a glance"
      asideTitle="What makes a dataset public here"
      asideItems={heroAsideItems}
    />
  </Fragment>

  <section id="public-v1" class="panel">
    <p class="section-label">Public V1</p>
    <h2>What the intentionally public v1 dataset is</h2>
    <div class="status-grid">
      {publicCards.map((card) => (
        <article class="status-card">
          <p class="kicker">{card.label}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="panel panel-accent">
    <p class="section-label">In / Out</p>
    <h2>What may be public, and what is not public by default</h2>
    <div class="dataset-grid">
      <article class="dataset-card">
        <h3>May be public in the v1 release</h3>
        <ul>
          {mayBePublic.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="dataset-card">
        <h3>Not public by default</h3>
        <ul>
          {notPublic.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section id="metadata" class="panel">
    <p class="section-label">Required Metadata</p>
    <h2>What should accompany any public dataset release</h2>
    <div class="mini-grid action-grid">
      {metadataCards.map((card) => (
        <article>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="panel">
    <p class="section-label">Reference Artifacts</p>
    <h2>Useful public files for data consumers right now</h2>
    <div class="action-card-grid">
      {referenceCards.map((card) => (
        <article class="action-card">
          <h3>{card.title}</h3>
          <p>{card.body}</p>
          <a class="text-link" href={card.href}>{card.label}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="panel caution">
    <p class="section-label">Before Publishing</p>
    <h2>Checklist before a dataset goes public</h2>
    <ul>
      {checklist.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section id="read-first" class="panel">
    <p class="section-label">Read First</p>
    <h2>Canonical policy documents</h2>
    <div class="link-groups">
      {readFirstLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </section>

  <Fragment slot="footer">
    <p>
      A public v1 dataset is an explicit release choice, not a blanket rule for all
      future parcel-linked data. The private-by-default promise still governs future
      participant data unless a later policy decision says otherwise.
    </p>
  </Fragment>
</SiteLayout>
