---
import SiteLayout from "../layouts/SiteLayout.astro";
import PageHero from "../components/PageHero.astro";
import Accordion from "../components/Accordion.astro";
import { repoLinks } from "../lib/repo-links";
import { faqs } from "../data/faqs";

const pageLinks = [
  { href: "index.html", label: "Main release" },
  { href: "dataset.html", label: "Dataset boundary" },
  { href: "release-notes.html", label: "Release notes" }
];

const heroAsideItems = [
  "What is public now?",
  "Is all data public?",
  "Is this emergency guidance?",
  "How do I build or contribute?"
];

const readNextLinks = [
  { href: repoLinks.ip, label: "IP position" },
  { href: repoLinks.datasetReleasePolicy, label: "Dataset release policy" },
  { href: repoLinks.dataOwnership, label: "Data ownership" },
  { href: repoLinks.privacy, label: "Privacy" },
  { href: repoLinks.claimsAndLimitations, label: "Claims and limitations" },
  { href: repoLinks.rootLicenses, label: "Licensing matrix" },
  { href: repoLinks.operatorQuickstart, label: "Operator quickstart" },
  { href: "release-notes.html", label: "Release notes" },
  { href: "dataset.html", label: "Dataset boundary page" }
];
---

<SiteLayout
  title="Resilient Home Intelligence FAQ"
  description="Frequently asked questions for the Resilient Home Intelligence v0.1 open release."
  ogDescription="Common questions about openness, data boundaries, safety claims, and how to use the release."
>
  <Fragment slot="hero">
    <PageHero
      eyebrow="FAQ"
      title="Short answers to the questions people will ask first."
      lede="This page is the fast path for the recurring questions about openness, data rights, safety claims, licensing, and what the release actually includes."
      pageLinks={pageLinks}
      asideLabel="Best use"
      asideTitle="Send this before sending the whole repo."
      asideItems={heroAsideItems}
    />
  </Fragment>

  <section class="panel">
    <p class="section-label">FAQ</p>
    <h2>Common questions</h2>
    <div class="faq-list">
      {faqs.map((item, i) => (
        <Accordion title={item.question} open={i === 0}>
          <p>{item.answer}</p>
        </Accordion>
      ))}
    </div>
  </section>

  <section class="panel">
    <p class="section-label">Read Next</p>
    <h2>Canonical docs behind these answers</h2>
    <div class="link-groups">
      {readNextLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </section>

  <Fragment slot="footer">
    <p>
      Use the FAQ for the short answer. Use the policy docs for the authoritative
      answer.
    </p>
  </Fragment>
</SiteLayout>
