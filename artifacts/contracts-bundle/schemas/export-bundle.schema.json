{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/resilient-home-intelligence/schemas/export-bundle.schema.json",
  "title": "OESIS Export Bundle",
  "type": "object",
  "required": [
    "generated_at",
    "parcel_id",
    "sharing",
    "rights_requests",
    "access_events",
    "parcel_state",
    "house_state",
    "house_capability",
    "control_compatibility",
    "intervention_events",
    "verification_outcomes"
  ],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "parcel_id": {
      "type": "string",
      "minLength": 1
    },
    "sharing": {
      "type": ["object", "null"]
    },
    "rights_requests": {
      "type": "array"
    },
    "access_events": {
      "type": "array"
    },
    "parcel_state": {
      "type": ["object", "null"]
    },
    "house_state": {
      "type": ["object", "null"]
    },
    "house_capability": {
      "type": ["object", "null"]
    },
    "control_compatibility": {
      "type": ["object", "null"]
    },
    "intervention_events": {
      "type": "array"
    },
    "verification_outcomes": {
      "type": "array"
    }
  }
}
