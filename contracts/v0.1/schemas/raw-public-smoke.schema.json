{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/oesis-program-specs/contracts/v0.1/schemas/raw-public-smoke.schema.json",
  "title": "OESIS Raw Public Smoke Context",
  "type": "object",
  "required": [
    "source_name",
    "observed_at",
    "parcel_id",
    "regional_pm25_ugm3",
    "smoke_advisory_level"
  ],
  "additionalProperties": false,
  "properties": {
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "parcel_id": {
      "type": "string",
      "minLength": 1
    },
    "regional_pm25_ugm3": {
      "type": "number",
      "minimum": 0
    },
    "smoke_advisory_level": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "moderate",
        "high",
        "very_high"
      ]
    }
  }
}
