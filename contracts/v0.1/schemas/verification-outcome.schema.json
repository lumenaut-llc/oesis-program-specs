{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/oesis-program-specs/schemas/verification-outcome.schema.json",
  "title": "OESIS Verification Outcome",
  "type": "object",
  "required": [
    "parcel_id",
    "verification_id",
    "verified_at",
    "hazard_type",
    "result_class"
  ],
  "additionalProperties": false,
  "properties": {
    "parcel_id": { "type": "string", "minLength": 1 },
    "verification_id": { "type": "string", "minLength": 1 },
    "verified_at": { "type": "string", "format": "date-time" },
    "intervention_ref": { "type": "string", "minLength": 1 },
    "hazard_type": { "type": "string", "enum": ["smoke", "heat", "flood", "outage", "other"] },
    "response_window_minutes": { "type": "integer", "minimum": 1 },
    "result_class": { "type": "string", "enum": ["improved", "unchanged", "worsened", "inconclusive"] },
    "before": { "type": "object" },
    "after": { "type": "object" },
    "summary": { "type": "string", "minLength": 1 }
  }
}
