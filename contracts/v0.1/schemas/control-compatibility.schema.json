{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/oesis-program-specs/schemas/control-compatibility.schema.json",
  "title": "OESIS Control Compatibility",
  "type": "object",
  "required": [
    "parcel_id",
    "effective_at",
    "endpoints"
  ],
  "additionalProperties": false,
  "properties": {
    "parcel_id": {
      "type": "string",
      "minLength": 1
    },
    "effective_at": {
      "type": "string",
      "format": "date-time"
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "label",
          "endpoint_type",
          "integration_class",
          "local_control_available"
        ],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "endpoint_type": { "type": "string", "minLength": 1 },
          "integration_class": {
            "type": "string",
            "enum": ["matter", "home_assistant", "bacnet", "smart_plug", "local_api", "cloud_only", "unknown"]
          },
          "local_control_available": { "type": "boolean" },
          "advisory_only": { "type": "boolean" },
          "soft_integration": { "type": "boolean" },
          "harder_integration": { "type": "boolean" },
          "override_required": { "type": "boolean" }
        }
      }
    }
  }
}
