{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/oesis-program-specs/v1.0/schemas/research-data-export.schema.json",
  "title": "OESIS Research Data Export (v1.0)",
  "type": "object",
  "required": [
    "export_id",
    "research_program_id",
    "program_parcel_id",
    "generated_at",
    "consent_verified",
    "retention_expires_at",
    "publication_allowed",
    "anonymization_level",
    "payload_schema_version",
    "data_payload"
  ],
  "additionalProperties": false,
  "properties": {
    "export_id": {
      "type": "string",
      "minLength": 1
    },
    "research_program_id": {
      "type": "string",
      "minLength": 1
    },
    "program_parcel_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "consent_verified": {
      "type": "boolean",
      "const": true
    },
    "retention_expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "publication_allowed": {
      "type": "boolean"
    },
    "anonymization_level": {
      "type": "string",
      "enum": [
        "parcel_ref_only",
        "structural_anonymization",
        "full_anonymization"
      ]
    },
    "payload_schema_version": {
      "type": "string",
      "minLength": 1
    },
    "data_payload": {
      "type": "object",
      "required": [
        "extracted_fields",
        "extraction_window",
        "source_contract_version"
      ],
      "properties": {
        "extracted_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "extraction_window": {
          "type": "object",
          "required": [
            "from",
            "to"
          ],
          "additionalProperties": false,
          "properties": {
            "from": {
              "type": "string",
              "format": "date-time"
            },
            "to": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "source_contract_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "audit_trail": {
      "type": "object",
      "properties": {
        "program_operator": {
          "type": "string",
          "minLength": 1
        },
        "access_logged": {
          "type": "boolean"
        },
        "export_timestamp": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
