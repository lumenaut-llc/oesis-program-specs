---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PublicPage from "../components/PublicPage.astro";

const entry = await getEntry("publicPages", "governance-and-privacy");

if (!entry) {
  throw new Error("Missing public page content for governance-and-privacy.");
}

const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <PublicPage
    eyebrow={entry.data.eyebrow}
    heroTitle={entry.data.heroTitle}
    intro={entry.data.intro}
    readNext={entry.data.readNext}
    showDiagrams={entry.data.showDiagrams}
    Content={Content}
  />
</BaseLayout>
