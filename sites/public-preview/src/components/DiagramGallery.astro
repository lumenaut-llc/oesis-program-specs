---
import { publicDiagrams } from "../data/diagramContent";
---

<section class="panel">
  <h2>Diagram gallery</h2>
  <div class="diagram-grid">
    {
      publicDiagrams.map((diagram) => (
        <article class="diagram-card">
          <div class="diagram-copy">
            <h3>{diagram.title}</h3>
            <p>{diagram.description}</p>
            <p class="diagram-takeaway"><strong>Takeaway:</strong> {diagram.takeaway}</p>
            <dl class="diagram-meta">
              <div>
                <dt>Audience</dt>
                <dd>{diagram.audience}</dd>
              </div>
              <div>
                <dt>Version relevance</dt>
                <dd>{diagram.versionRelevance}</dd>
              </div>
              <div>
                <dt>Purpose</dt>
                <dd>{diagram.purpose}</dd>
              </div>
            </dl>
            {
              diagram.relatedSpecs && (
                <div class="diagram-links">
                  <span class="diagram-links-label">Related released specs</span>
                  <ul class="spec-link-list">
                    {diagram.relatedSpecs.map((link) => (
                      <li><a href={link.href} target="_blank" rel="noreferrer">{link.label}</a></li>
                    ))}
                  </ul>
                </div>
              )
            }
          </div>
          <pre class="mermaid diagram-render">{diagram.code}</pre>
        </article>
      ))
    }
  </div>
</section>

<script is:inline>
  const diagrams = document.querySelectorAll(".mermaid");

  if (diagrams.length > 0) {
    const script = document.createElement("script");
    script.src = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js";
    script.onload = async () => {
      if (!window.mermaid) return;
      window.mermaid.initialize({
        startOnLoad: false,
        securityLevel: "strict",
        theme: "neutral"
      });
      await window.mermaid.run({ nodes: diagrams });
    };
    document.head.appendChild(script);
  }
</script>
