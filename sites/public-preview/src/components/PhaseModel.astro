---
interface PhaseStep {
  label: string;
  title: string;
  body: string;
}

interface PhaseGroup {
  bridge: string;
  title: string;
  outcome: string;
  phases: PhaseStep[];
}

interface Props {
  groups: PhaseGroup[];
}

const { groups } = Astro.props;
---

<div class="phase-model-grid">
  {
    groups.map((group) => (
      <article class="phase-group">
        <p class="phase-bridge">{group.bridge}</p>
        <h3>{group.title}</h3>
        <p class="phase-outcome">{group.outcome}</p>
        <ol class="phase-steps" aria-label={`${group.bridge} capability phases`}>
          {
            group.phases.map((phase) => (
              <li class="phase-step">
                <span class="phase-step-label">{phase.label}</span>
                <div class="phase-step-copy">
                  <strong>{phase.title}</strong>
                  <p>{phase.body}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </article>
    ))
  }
</div>
