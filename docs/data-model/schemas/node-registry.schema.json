{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumenaut-llc.github.io/resilient-home-intelligence/schemas/node-registry.schema.json",
  "title": "OESIS Node Registry",
  "type": "object",
  "required": [
    "updated_at",
    "parcel_id",
    "nodes"
  ],
  "additionalProperties": false,
  "properties": {
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "parcel_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "node_class",
          "hardware_family",
          "schema_version",
          "observation_family",
          "location_mode",
          "install_role",
          "transport_mode",
          "power_mode",
          "calibration_state",
          "installed_at",
          "last_seen_at",
          "enabled"
        ],
        "additionalProperties": false,
        "properties": {
          "node_id": {
            "type": "string",
            "minLength": 1
          },
          "node_class": {
            "type": "string",
            "enum": [
              "indoor_air",
              "outdoor_reference",
              "outdoor_pm_weather",
              "low_point_flood",
              "thermal_scene"
            ]
          },
          "hardware_family": {
            "type": "string",
            "enum": [
              "bench-air-node",
              "mast-lite",
              "weather-pm-mast",
              "flood-node",
              "thermal-pod"
            ]
          },
          "schema_version": {
            "type": "string",
            "minLength": 1
          },
          "observation_family": {
            "type": "string",
            "minLength": 1
          },
          "location_mode": {
            "type": "string",
            "enum": [
              "indoor",
              "sheltered",
              "outdoor"
            ]
          },
          "install_role": {
            "type": "string",
            "minLength": 1
          },
          "transport_mode": {
            "type": "string",
            "enum": [
              "serial_only",
              "serial_bridge",
              "https_push",
              "mqtt"
            ]
          },
          "power_mode": {
            "type": "string",
            "enum": [
              "usb_c_mains",
              "ac_adapter",
              "poe",
              "battery",
              "solar_assist"
            ]
          },
          "calibration_state": {
            "type": "string",
            "enum": [
              "provisional",
              "verified",
              "needs_service",
              "unsupported"
            ]
          },
          "installed_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen_at": {
            "type": "string",
            "format": "date-time"
          },
          "enabled": {
            "type": "boolean"
          },
          "firmware_version": {
            "type": "string",
            "minLength": 1
          },
          "privacy_mode": {
            "type": "string",
            "enum": [
              "derived_only",
              "bounded_internal",
              "full_frame_internal"
            ]
          }
        }
      }
    }
  }
}
